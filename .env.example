# === CROO CAP credentials (from the Agent Store dashboard, shown once) ===
# Provider agent: the one that LISTS the due-diligence service and earns USDC.
CROO_SDK_KEY=croo_sk_your_provider_key_here

# API + network endpoints (defaults are Base mainnet)
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_RPC_URL=https://mainnet.base.org

# The serviceId you created in the dashboard for "Token Due-Diligence Report".
# Used by the requester demo to know what to hire.
CROO_SERVICE_ID=svc_...

# === Requester agent (A2A demo) — a SECOND agent that hires the provider ===
# Fund this agent's AA wallet with a little USDC on Base to pay for a call.
# This is also Zodyl's key (Zodyl = the ecosystem's portfolio agent).
CROO_REQUESTER_SDK_KEY=croo_sk_your_requester_key_here

# === Ecosystem: Zodyl (portfolio agent) as a PROVIDER ===
# Zodyl lists a "Portfolio Risk Scan" service that hires Quanta per token.
# Its SDK key (falls back to CROO_REQUESTER_SDK_KEY if unset — same agent).
CROO_ZODYL_SDK_KEY=
# The serviceId of Zodyl's portfolio-scan service (from the dashboard).
CROO_ZODYL_SERVICE_ID=
# Buyer for the portfolio demo — any funded agent that is NOT Zodyl.
# Falls back to CROO_SDK_KEY (Quanta) for a local demo.
CROO_BUYER_SDK_KEY=

# === Ecosystem registry / capability router ("CEO brain") ===
# Quanta routes each needed capability to a specialist: its OWN ecosystem agents
# first, then the open store. Internal agents are declared by their service-id
# env vars above (CROO_SERVICE_ID -> Quanta due-diligence, CROO_ZODYL_SERVICE_ID
# -> Zodyl portfolio-scan). Store fallbacks are a JSON array here:
#   e.g. [{"capability":"due-diligence","serviceId":"svc_x","agentName":"Argus","price":0.1}]
CROO_STORE_SERVICES=
# The capability Quanta requests as a per-order enrichment annex (default
# "due-diligence" — a second opinion; self-excluded so Quanta never hires itself,
# so this only fires when a store/other agent offers it).
CROO_ENRICH_CAPABILITY=

# === Optional: A2A upstream enrichment (legacy single hook) ===
# Still supported: a single store service folded into the router as a store entry
# for CROO_UPSTREAM_CAPABILITY (default "due-diligence"). Prefer CROO_STORE_SERVICES.
CROO_UPSTREAM_SERVICE_ID=
CROO_UPSTREAM_CAPABILITY=
# Hard cap on how long to wait for an upstream delivery (default 90000 ms).
CROO_UPSTREAM_TIMEOUT_MS=

# === Optional: LLM intelligence overlay (via dgrid — one key, all models) ===
# If set, premium deliverables add an Opus 4.8 analyst brief + risk reasoning,
# grounded ONLY in the verified facts (never invents numbers) and EXCLUDED from
# the on-chain-hashed verifiable core. Omit to run purely on the deterministic,
# source-cited data engine. dgrid is OpenAI-compatible: POST /v1/chat/completions.
DGRID_API_KEY=sk-your_dgrid_key_here
DGRID_BASE_URL=https://api.dgrid.ai/v1
QUANTA_LLM_MODEL=claude-opus-4-8      # any dgrid model id, e.g. claude-haiku-4-5, x-ai/grok...

# Legacy direct-Anthropic path (used only if DGRID_API_KEY is unset).
ANTHROPIC_API_KEY=
